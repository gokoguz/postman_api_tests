          "name": "TC-API-003 : GET /booking - GetBookingIds - Tüm Rezervasyonları Listele (Pozitif)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-API-003: GET /booking — Tüm rezervasyonları listele",
                  "",
                  "pm.test('[TC-API-004] HTTP Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[TC-API-004] Response time < 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[TC-API-004] Content-Type: application/json', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('[TC-API-004] Response body bir dizi (array) döner', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('[TC-API-004] Dizi boş değil', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('[TC-API-004] Her eleman bookingid alanına sahip', function () {",
                  "    const json = pm.response.json();",
                  "    json.forEach(function(item) {",
                  "        pm.expect(item).to.have.property('bookingid');",
                  "        pm.expect(item.bookingid).to.be.a('number');",
                  "    });",
                  "});",
                  "",
                  "// İlk bookingid'i kaydet",
                  "const json = pm.response.json();",
                  "if (json.length > 0) {",
                  "    pm.environment.set('existingBookingId', json[0].bookingid);",
                  "    console.log('Kaydedilen bookingId:', json[0].bookingid);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
