        {
          "name": "TC-API-011 : POST /booking - CreateBooking - Yeni Rezervasyon Oluştur (Pozitif)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-API-011: POST /booking — Yeni rezervasyon oluştur",
                  "",
                  "pm.test('[TC-API-008] HTTP Status 200 OK (API 201 değil 200 döner)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('[TC-API-008] Response time < 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "pm.test('[TC-API-008] Content-Type: application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('[TC-API-008] bookingid döner ve sayısal değer', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('bookingid');",
                  "    pm.expect(json.bookingid).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('[TC-API-008] booking nesnesi response içinde mevcut', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('booking');",
                  "    pm.expect(json.booking).to.have.property('firstname');",
                  "    pm.expect(json.booking).to.have.property('lastname');",
                  "    pm.expect(json.booking).to.have.property('totalprice');",
                  "    pm.expect(json.booking).to.have.property('depositpaid');",
                  "    pm.expect(json.booking).to.have.property('bookingdates');",
                  "});",
                  "",
                  "pm.test('[TC-API-008] Response body, gönderilen değerlerle eşleşiyor', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.booking.firstname).to.equal('Test');",
                  "    pm.expect(json.booking.lastname).to.equal('Customer');",
                  "    pm.expect(json.booking.totalprice).to.equal(157);",
                  "    pm.expect(json.booking.depositpaid).to.be.true;",
                  "});",
                  "",
                  "// Oluşturulan ID'yi sonraki testler için kaydet",
                  "const json = pm.response.json();",
                  "if (json.bookingid) {",
                  "    pm.environment.set('newBookingId', json.bookingid);",
                  "    console.log('Yeni bookingId:', json.bookingid);",
                  "}"
                ],
